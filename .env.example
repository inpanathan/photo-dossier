# =============================================================================
# Dossier Application Configuration
# =============================================================================
# Copy this file to .env and edit values as needed.
# Comments must be on their own line — never inline (REQ-CFG-006).

# ---- Application ----

# Environment: dev, staging, production, test
APP_ENV=dev

# Enable debug mode (Swagger docs, verbose logging)
APP_DEBUG=true

# Secret key for JWT signing and session encryption
# CHANGE THIS in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-IN-PRODUCTION

# ---- Server ----

# Server bind address and port
SERVER__HOST=0.0.0.0
SERVER__PORT=8000
SERVER__WORKERS=1
SERVER__RELOAD=true

# ---- Logging ----

# Log level: DEBUG, INFO, WARNING, ERROR
LOGGING__LEVEL=INFO

# Log format: json or console
LOGGING__FORMAT=json

# ---- Admin Console ----

# Secret key for admin API access (X-Admin-Secret header)
ADMIN__SECRET_KEY=admin-secret-change-me

# Directories allowed for static file mounts (JSON array)
ADMIN__ALLOWED_BASE_DIRS=["data", "static"]

# Path to mount configuration file
ADMIN__MOUNTS_FILE=data/static_mounts.json

# ---- Photo Corpus ----

# Directory containing the photo corpus to index
CORPUS__CORPUS_DIR=data/corpus

# Supported image formats (JSON array)
CORPUS__SUPPORTED_FORMATS=["jpg", "jpeg", "png", "heic", "heif"]

# Maximum image file size in MB
CORPUS__MAX_IMAGE_SIZE_MB=50

# ---- Inference Service (7810 Node) ----

# Base URL of the remote inference service (InsightFace + YOLOv8 + DINOv2)
INFERENCE__BASE_URL=http://100.111.31.125:8010

# Request timeout in seconds
INFERENCE__TIMEOUT_SECONDS=30

# Minimum confidence thresholds for detection
INFERENCE__MIN_FACE_CONFIDENCE=0.5
INFERENCE__MIN_PET_CONFIDENCE=0.4

# ---- FAISS Vector Index ----

# Directory for FAISS index files
INDEX__FAISS_INDEX_DIR=data/indices

# SQLite metadata database path
INDEX__METADATA_DB_PATH=data/metadata.db

# Similarity thresholds for retrieval (cosine similarity)
INDEX__HUMAN_SIMILARITY_THRESHOLD=0.6
INDEX__PET_SIMILARITY_THRESHOLD=0.5

# Default number of results to return
INDEX__DEFAULT_TOP_K=50

# ---- Narrative Generation (LLM/VLM) ----

# Local vLLM endpoint for dossier narrative generation (Qwen2.5-14B-Instruct-AWQ)
NARRATIVE__LLM_BASE_URL=http://localhost:8001/v1
NARRATIVE__LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
NARRATIVE__LLM_MAX_TOKENS=4000

# VLM endpoint for photo descriptions (Qwen2.5-VL-7B on 7810 GPU 1)
NARRATIVE__VLM_BASE_URL=http://100.111.31.125:8011/v1
NARRATIVE__VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
NARRATIVE__VLM_MAX_TOKENS=500

# Generation temperature (lower = more focused)
NARRATIVE__TEMPERATURE=0.3

# ---- Async Job Queue ----

# Maximum number of concurrent background jobs
JOBS__MAX_CONCURRENT_JOBS=4

# Job timeout in seconds
JOBS__JOB_TIMEOUT_SECONDS=600

# How long to keep completed job results (seconds)
JOBS__RESULT_TTL_SECONDS=3600

# ---- Photo Upload ----

# Maximum upload file size in MB
UPLOAD__MAX_FILE_SIZE_MB=20

# Upload storage directory
UPLOAD__UPLOAD_DIR=data/uploads

# Accepted MIME types (JSON array)
UPLOAD__ACCEPTED_TYPES=["image/jpeg", "image/png", "image/heic"]

# ---- Security ----

# Rate limit: requests per minute per IP (0 = disabled)
SECURITY__RATE_LIMIT_RPM=60

# JWT token expiry in seconds (default: 24 hours)
SECURITY__JWT_EXPIRY_SECONDS=86400

# Require JWT authentication on API endpoints
SECURITY__REQUIRE_AUTH=false
