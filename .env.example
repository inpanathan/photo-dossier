# Application environment: dev | staging | production | test
APP_ENV=dev
APP_DEBUG=true

# Secret key — CHANGE THIS in staging/production
SECRET_KEY=CHANGE-ME-IN-PRODUCTION

# Model backend: mock | local | cloud
MODEL_BACKEND=mock

# Set to true to use mock implementations for external services
USE_MOCKS=true

# API keys (add your project-specific keys here)
# LLM_API_KEY=
# EMBEDDING_API_KEY=

# Logging
LOGGING__LEVEL=DEBUG
LOGGING__FORMAT=console
